---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found"
  description="This page doesn't exist."
>
  <div class="container py-32 sm:py-48 flex flex-col items-center text-center">
    <p class="text-8xl sm:text-9xl font-bold text-zinc-100 dark:text-zinc-800 font-mono select-none mb-6">404</p>
    <h1 class="text-2xl sm:text-3xl font-bold tracking-tight mb-4">Page not found</h1>
    <p class="text-zinc-500 dark:text-zinc-400 mb-8 max-w-sm leading-relaxed">
      The page you're looking for doesn't exist or may have been moved.
    </p>
    <a href="/" class="btn-primary">Back to home</a>
  </div>
</BaseLayout>
