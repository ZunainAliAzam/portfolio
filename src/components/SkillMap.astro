---
const W = 1000;
const H = 600;

interface Skill {
  id: string;
  label: string;
  icon?: string | null;
}

interface Category {
  id: string;
  label: string;
  color: string;
  mapX: number;
  mapY: number;
  skills: Skill[];
}

const categories: Category[] = [
  {
    id: 'frontend', label: 'Frontend', color: '#f97316',
    mapX: 190, mapY: 178,
    skills: [
      { id: 'react',      label: 'React.js',      icon: 'react' },
      { id: 'nextjs',     label: 'Next.js',        icon: 'nextjs' },
      { id: 'angular',    label: 'Angular',         icon: 'angular' },
      { id: 'typescript', label: 'TypeScript',      icon: 'ts' },
      { id: 'tailwind',   label: 'Tailwind CSS',    icon: 'tailwind' },
      { id: 'angmat',     label: 'Ang. Material',   icon: 'materialui' },
      { id: 'redux',      label: 'Redux Toolkit',   icon: 'redux' },
      { id: 'tanstack',   label: 'TanStack Query',  icon: '__local__/React-Query-Icon.svg' },
    ],
  },
  {
    id: 'backend', label: 'Backend', color: '#a78bfa',
    mapX: 800, mapY: 178,
    skills: [
      { id: 'nodejs',  label: 'Node.js',    icon: 'nodejs' },
      { id: 'express', label: 'Express.js', icon: 'express' },
      { id: 'nestjs',  label: 'NestJS',     icon: 'nestjs' },
    ],
  },
  {
    id: 'database', label: 'Database', color: '#38bdf8',
    mapX: 235, mapY: 452,
    skills: [
      { id: 'postgresql', label: 'PostgreSQL', icon: 'postgresql' },
      { id: 'mongodb',    label: 'MongoDB',    icon: 'mongodb' },
      { id: 'firestore',  label: 'Firestore',  icon: '__local__/firebase.png' },
      { id: 'mysql',      label: 'MySQL',      icon: 'mysql' },
    ],
  },
  {
    id: 'cloud', label: 'Cloud & Tools', color: '#34d399',
    mapX: 758, mapY: 452,
    skills: [
      { id: 'firebase', label: 'Firebase', icon: 'firebase' },
      { id: 'git',      label: 'Git',      icon: 'git' },
      { id: 'aws',      label: 'AWS',      icon: 'aws' },
      { id: 'vercel',   label: 'Vercel',   icon: 'vercel' },
      { id: 'monorepo', label: 'MonoRepo', icon: null },
    ],
  },
];

const skillPos: Record<string, { x: number; y: number }> = {
  react: { x: 55, y: 85 },      nextjs: { x: 152, y: 40 },
  angular: { x: 290, y: 40 },   typescript: { x: 52, y: 198 },
  tailwind: { x: 160, y: 278 }, angmat: { x: 298, y: 278 },
  redux: { x: 400, y: 90 },     tanstack: { x: 400, y: 180 },
  nodejs: { x: 920, y: 88 },    express: { x: 843, y: 280 },
  nestjs: { x: 720, y: 88 },
  postgresql: { x: 72, y: 390 }, mongodb: { x: 132, y: 505 },
  firestore: { x: 268, y: 548 }, mysql: { x: 395, y: 510 },
  firebase: { x: 880, y: 390 }, git: { x: 888, y: 505 },
  aws: { x: 758, y: 548 },      vercel: { x: 628, y: 510 },
  monorepo: { x: 618, y: 388 },
};

const CX = 500, CY = 300;

function iconSrc(icon: string | null | undefined): string | null {
  if (!icon) return null;
  if (icon.startsWith('__local__/')) return `/${icon.replace('__local__/', '')}`;
  return `https://skillicons.dev/icons?i=${icon}&theme=dark`;
}

function iconSrcLight(icon: string | null | undefined): string | null {
  if (!icon) return null;
  if (icon.startsWith('__local__/')) return `/${icon.replace('__local__/', '')}`;
  return `https://skillicons.dev/icons?i=${icon}&theme=light`;
}

function badge(label: string) {
  return label.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
}

function curve(fx: number, fy: number, tx: number, ty: number) {
  const dx = tx - fx;
  return `M ${fx} ${fy} C ${fx + dx * 0.5} ${fy} ${tx - dx * 0.5} ${ty} ${tx} ${ty}`;
}
---

<!-- Mobile / Tablet: categorized skill cards (hidden on lg+) -->
<div class="lg:hidden grid grid-cols-1 sm:grid-cols-2 gap-4 px-4 sm:px-6 lg:px-8">
  {categories.map(cat => (
    <div class="skill-card" style={`--c:${cat.color};`}>
      <h3 class="skill-card-title">{cat.label}</h3>
      <div class="skill-card-grid">
        {cat.skills.map(skill => {
          const src = iconSrc(skill.icon);
          return (
            <div class="skill-item">
              {src
                ? <img src={src} alt={skill.label} width="20" height="20" loading="lazy" class="skill-item-img" />
                : <span class="skill-item-badge">{badge(skill.label)}</span>
              }
              <span class="skill-item-label">{skill.label}</span>
            </div>
          );
        })}
      </div>
    </div>
  ))}
</div>

<!-- Desktop: full-width scaled mind map (hidden below lg) -->
<div class="hidden lg:block" id="skillmap-scaler" style="position:relative;overflow:hidden;width:100%;">
  <div id="skillmap-inner" style={`width:${W}px;height:${H}px;position:absolute;top:0;left:0;transform-origin:top left;`}>

    <!-- Dot-grid background -->
    <svg width={W} height={H} style="position:absolute;inset:0;pointer-events:none;opacity:0.055;">
      <defs>
        <pattern id="dotgrid" width="32" height="32" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="white"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotgrid)"/>
    </svg>

    <!-- Edges + endpoint markers -->
    <svg width={W} height={H} style="position:absolute;inset:0;pointer-events:none;">
      {/* Hub → categories */}
      {categories.map(cat => (
        <path d={curve(CX, CY, cat.mapX, cat.mapY)}
          stroke={cat.color} stroke-width="1.5" stroke-opacity="0.55"
          fill="none" stroke-linecap="round"/>
      ))}
      {/* Categories → skills */}
      {categories.flatMap(cat =>
        cat.skills
          .filter(s => skillPos[s.id])
          .map(s => (
            <path d={curve(cat.mapX, cat.mapY, skillPos[s.id].x, skillPos[s.id].y)}
              stroke={cat.color} stroke-width="1" stroke-opacity="0.28"
              fill="none" stroke-linecap="round"/>
          ))
      )}
      {/* Skill dots */}
      {categories.flatMap(cat =>
        cat.skills
          .filter(s => skillPos[s.id])
          .map(s => <circle cx={skillPos[s.id].x} cy={skillPos[s.id].y} r="2.5" fill={cat.color} opacity="0.55"/>)
      )}
      {/* Category dots */}
      {categories.map(cat => (
        <circle cx={cat.mapX} cy={cat.mapY} r="3" fill={cat.color} opacity="0.7"/>
      ))}
    </svg>

    <!-- Hub -->
    <div class="sm-node sm-node--hub" style={`left:${CX}px;top:${CY}px;`}>
      <span class="sm-hub-text">My Stack</span>
    </div>

    <!-- Category nodes -->
    {categories.map(cat => (
      <div class="sm-node sm-node--category" style={`left:${cat.mapX}px;top:${cat.mapY}px;--c:${cat.color};`}>
        <span class="sm-cat-text">{cat.label}</span>
      </div>
    ))}

    <!-- Skill nodes -->
    {categories.flatMap(cat =>
      cat.skills
        .filter(s => skillPos[s.id])
        .map(s => {
          const pos = skillPos[s.id];
          const src = iconSrc(s.icon);
          return (
            <div class="sm-node sm-node--skill" style={`left:${pos.x}px;top:${pos.y}px;--c:${cat.color};`}>
              {src
                ? <img src={src} alt={s.label} width="32" height="32" loading="lazy" class="sm-icon"/>
                : <span class="sm-badge">{badge(s.label)}</span>
              }
              <span class="sm-skill-label">{s.label}</span>
            </div>
          );
        })
    )}
  </div>
</div>

<script>
  const scaler = document.getElementById('skillmap-scaler');
  const inner  = document.getElementById('skillmap-inner');

  function resize() {
    if (!scaler || !inner) return;
    const scale = scaler.clientWidth / 1000;
    inner.style.transform = `scale(${scale})`;
    scaler.style.height   = `${600 * scale}px`;
  }

  resize();
  window.addEventListener('resize', resize, { passive: true });
</script>

<style>
  /* ── Mobile cards ─────────────────────────────────── */
  .skill-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-top: 2px solid var(--c);
    border-radius: 12px;
    padding: 16px;
  }

  .skill-card-title {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c);
    margin-bottom: 12px;
  }

  .skill-card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 6px;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11.5px;
    color: rgba(255,255,255,0.65);
    min-width: 0;
  }

  .skill-item-img {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .skill-item-badge {
    width: 20px;
    height: 20px;
    border-radius: 4px;
    background: var(--c);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 800;
    color: white;
    font-family: monospace;
    flex-shrink: 0;
  }

  .skill-item-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: black
  }

  /* ── Desktop map ──────────────────────────────────── */
  .sm-node {
    position: absolute;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    user-select: none;
  }

  .sm-node--hub {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: conic-gradient(from 160deg, #f97316, #ec4899, #f97316);
    justify-content: center;
    box-shadow: 0 0 0 8px rgba(249,115,22,0.07), 0 0 48px rgba(249,115,22,0.22);
    animation: hubPulse 3.5s ease-in-out infinite;
  }

  .sm-hub-text {
    font-size: 9px;
    font-weight: 800;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-align: center;
    line-height: 1.25;
    padding: 0 6px;
  }

  .sm-node--category {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--c);
    border-radius: 20px;
    padding: 4px 14px;
    white-space: nowrap;
    box-shadow: 0 0 14px color-mix(in srgb, var(--c) 14%, transparent);
  }

  .sm-cat-text {
    font-size: 10px;
    font-weight: 700;
    color: var(--c);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .sm-node--skill {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 8px 10px;
    min-width: 76px;
    max-width: 90px;
    cursor: default;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .sm-node--skill:hover {
    background: rgba(255,255,255,0.08);
    border-color: var(--c);
    box-shadow: 0 0 20px color-mix(in srgb, var(--c) 20%, transparent);
    transform: translate(-50%, -50%) scale(1.08);
    z-index: 10;
  }

  .sm-icon {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .sm-badge {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--c), rgba(255,255,255,0.08));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 800;
    color: white;
    font-family: monospace;
    margin: 0 auto;
  }

  .sm-skill-label {
    font-size: 9.5px;
    color: rgba(255,255,255,0.5);
    text-align: center;
    line-height: 1.3;
    transition: color 0.2s;
  }

  .sm-node--skill:hover .sm-skill-label {
    color: rgba(255,255,255,0.92);
  }

  :global(html:not(.dark)) .skill-item,
  :global(html:not(.dark)) .skill-item-label {
    color: rgba(0,0,0,0.7);
  }

  :global(html:not(.dark)) .skill-card {
    background: rgba(0,0,0,0.02);
    border-color: rgba(0,0,0,0.08);
  }

  :global(html:not(.dark)) .skill-item-badge,
  :global(html:not(.dark)) .sm-badge {
    color: #111;
  }
  :global(html:not(.dark)) .sm-badge {
    background: var(--c);
  }

  :global(html:not(.dark)) .sm-node--skill {
    background: rgba(0,0,0,0.03);
    border-color: rgba(0,0,0,0.1);
  }
  :global(html:not(.dark)) .sm-node--skill:hover {
    background: rgba(0,0,0,0.06);
  }
  :global(html:not(.dark)) .sm-skill-label {
    color: rgba(0,0,0,0.55);
  }
  :global(html:not(.dark)) .sm-node--skill:hover .sm-skill-label {
    color: rgba(0,0,0,0.85);
  }

  @keyframes hubPulse {
    0%, 100% { box-shadow: 0 0 0 8px rgba(249,115,22,0.07), 0 0 48px rgba(249,115,22,0.22); }
    50%       { box-shadow: 0 0 0 13px rgba(249,115,22,0.04), 0 0 60px rgba(249,115,22,0.3); }
  }
</style>
