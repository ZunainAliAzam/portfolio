---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resume"
  description="Resume of Zunain Ali Azam — Software Engineer specializing in React, Angular, Next.js, and TypeScript."
>
  <div class="container py-16 sm:py-24">
    <div class="mb-8" data-animate>
      <p class="section-label">Resume</p>
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">Zunain Ali Azam</h1>
          <p class="text-zinc-500 dark:text-zinc-400">Software Engineer</p>
        </div>
        <a
          href="/resume.pdf"
          download="Zunain Ali Azam - Resume.pdf"
          class="btn-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>
          </svg>
          Download PDF
        </a>
      </div>
    </div>

    <div class="w-full rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800 shadow-xl" data-animate>
      <iframe
        src="/resume.pdf"
        title="Zunain Ali Azam Resume"
        class="w-full"
        style="height: 85vh; min-height: 600px;"
      ></iframe>
    </div>
  </div>
</BaseLayout>
