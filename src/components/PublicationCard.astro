---
interface Props {
  title: string;
  description: string;
  publishedDate: string;
  readTime: string;
  link: string;
  tags?: string[];
}

const { title, description, publishedDate, readTime, link, tags = [] } = Astro.props;
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="card p-5 flex flex-col gap-3 group cursor-pointer"
>
  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="tech-tag">{tag}</span>
    ))}
  </div>

  <h3 class="font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug">
    {title}
  </h3>

  <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-2">
    {description}
  </p>

  <div class="flex items-center justify-between mt-auto pt-2 border-t border-zinc-200 dark:border-zinc-800">
    <div class="flex items-center gap-2 text-xs text-zinc-400 dark:text-zinc-500 font-mono">
      <span>{publishedDate}</span>
      <span>·</span>
      <span>{readTime}</span>
    </div>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-zinc-400 group-hover:text-indigo-500 transition-colors shrink-0"
    >
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
      <polyline points="15 3 21 3 21 9"/>
      <line x1="10" x2="21" y1="14" y2="3"/>
    </svg>
  </div>
</a>
