---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);
---

<article class="card p-6 flex flex-col gap-3 group relative">
  <div class="flex flex-wrap gap-1.5">
    {tags.slice(0, 3).map((tag) => (
      <span class="tech-tag">{tag}</span>
    ))}
  </div>

  <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors leading-snug">
    <a href={`/blog/${slug}`} class="stretched-link">{title}</a>
  </h3>

  <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-2">
    {description}
  </p>

  <time
    datetime={date.toISOString()}
    class="text-xs text-zinc-400 dark:text-zinc-500 font-mono mt-auto"
  >
    {formattedDate}
  </time>
</article>

<style>
  .stretched-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  article {
    position: relative;
  }
</style>
