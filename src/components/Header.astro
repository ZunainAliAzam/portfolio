---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/projects',   label: 'Projects',    icon: 'grid'   },
  { href: '/experience', label: 'Experience',  icon: 'brief'  },
  { href: '/blog',       label: 'Writing',     icon: 'pen'    },
  { href: '/about',      label: 'About',       icon: 'user'   },
  { href: '/contact',    label: 'Contact',     icon: 'mail'   },
];

const currentPath = Astro.url.pathname;

const icons: Record<string, string> = {
  home: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  grid: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>`,
  pen:  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>`,
  user: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M3 21a9 9 0 0 1 18 0"/></svg>`,
  mail:  `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  brief: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>`,
};
---

<!-- Desktop / top header -->
<header class="sticky top-0 z-50 bg-zinc-50/80 dark:bg-zinc-950/80 backdrop-blur-xl border-b border-zinc-200/60 dark:border-zinc-800/60">
  <div class="container">
    <div class="flex items-center justify-between h-14">

      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2.5 font-heading font-semibold text-zinc-900 dark:text-zinc-100 hover:text-orange-500 dark:hover:text-orange-400 transition-colors"
        aria-label="Home"
      >
        <span class="flex items-center justify-center w-8 h-8 bg-gradient-to-br from-orange-500 to-rose-500 text-white text-sm font-bold rounded-lg shadow-md shadow-orange-500/20">
          ZA
        </span>
        <span class="hidden sm:block text-sm">Zunain Ali Azam</span>
      </a>

      <!-- Floating pill nav — desktop only -->
      <nav class="hidden md:flex items-center gap-0.5 bg-zinc-100/80 dark:bg-zinc-900/80 backdrop-blur-xl border border-zinc-200 dark:border-zinc-700/60 rounded-full px-1.5 py-1.5 shadow-sm">
        {navLinks.map(({ href, label }) => {
          const active = currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                'px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200',
                active
                  ? 'bg-orange-500 text-white shadow-sm shadow-orange-500/30'
                  : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-200/70 dark:hover:bg-zinc-800',
              ]}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <!-- Right: theme toggle -->
      <div class="flex items-center gap-2">
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<!-- Mobile bottom nav -->
<nav
  class="fixed bottom-0 left-0 right-0 z-50 md:hidden"
  style="padding-bottom: env(safe-area-inset-bottom, 0px);"
  aria-label="Mobile navigation"
>
  <div class="flex items-center justify-around bg-zinc-50/95 dark:bg-zinc-950/95 backdrop-blur-xl border-t border-zinc-200/70 dark:border-zinc-800/70 h-16 px-1">
    <!-- Home -->
    <a
      href="/"
      class:list={[
        'flex flex-col items-center gap-0.5 py-1 px-3 rounded-xl transition-colors min-w-0',
        currentPath === '/'
          ? 'text-orange-500 dark:text-orange-400'
          : 'text-zinc-400 dark:text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300',
      ]}
      aria-label="Home"
    >
      <Fragment set:html={icons.home} />
      <span class="text-[10px] font-medium">Home</span>
    </a>

    {navLinks.map(({ href, label, icon }) => {
      const active = currentPath.startsWith(href);
      return (
        <a
          href={href}
          class:list={[
            'flex flex-col items-center gap-0.5 py-1 px-3 rounded-xl transition-colors min-w-0',
            active
              ? 'text-orange-500 dark:text-orange-400'
              : 'text-zinc-400 dark:text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300',
          ]}
          aria-label={label}
        >
          <Fragment set:html={icons[icon]} />
          <span class="text-[10px] font-medium">{label}</span>
        </a>
      );
    })}
  </div>
</nav>
